# ===========================================
# ZY Sales Trainer 环境变量配置示例
# ===========================================
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# -------------------------------------------
# 数据库配置 (PostgreSQL)
# -------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=zy_sales_trainer
POSTGRES_USER=zy_user
POSTGRES_PASSWORD=your_secure_password_here

# -------------------------------------------
# 应用配置
# -------------------------------------------
PORT=5000
NODE_ENV=production
HOSTNAME=0.0.0.0

# -------------------------------------------
# 对象存储配置 (可选)
# -------------------------------------------
# 使用本地存储（默认）
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# 使用 S3 兼容存储（如 Cloudflare R2、AWS S3）
# STORAGE_TYPE=s3
# S3_ENDPOINT=https://your-bucket.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET_NAME=your-bucket-name
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# -------------------------------------------
# LLM 配置 (可选)
# -------------------------------------------
# 使用内置模型（默认，无需配置）

# 使用 OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx

# 使用 DeepSeek
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxx

# -------------------------------------------
# 其他配置
# -------------------------------------------
# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 最大上传文件大小 (MB)
MAX_UPLOAD_SIZE=10

# 会话超时时间 (分钟)
SESSION_TIMEOUT=30
